    def taste_abfangen(self, event):
        if not self.aktueller_listener: return
        t_name = event.keysym.upper()
        scs_code = f"keyboard.{event.keysym.lower()}?0"
        
        if t_name == "SPACE": scs_code = "keyboard.space?0"
        elif "ALT" in t_name:
            if event.keycode == 108: t_name = "ALT GR"; scs_code = "keyboard.ralt?0"
            else: t_name = "LEFT ALT"; scs_code = "keyboard.lalt?0"
            
        self.zuweisen_an_ziel(t_name, scs_code)

    def universelle_maus_abfangen(self, event):
        if not self.aktueller_listener: return
        button_num = event.num
        scs_button = button_num
        display_name = f"MOUSE BTN {button_num}"
        
        if button_num == 1: display_name = "LINKS-KLICK"
        elif button_num == 2: display_name = "MAUSRAD-KLICK"
        elif button_num == 3: display_name = "RECHTS-KLICK"
        elif button_num == 4 or button_num == 8: 
            display_name = "MAUS DAUMEN 1"
            scs_button = 4  
        elif button_num == 5 or button_num == 9: 
            display_name = "MAUS DAUMEN 2"
            scs_button = 5  
            
        scs_code = f"mouse.button_{scs_button}?0"
        self.zuweisen_an_ziel(display_name, scs_code)

    def zuweisen_an_ziel(self, display_name, scs_code):
        if self.aktueller_listener == "turbo":
            self.taste_turbo_display, self.taste_turbo_code = display_name, scs_code
            self.btn_turbo.config(text=self.taste_turbo_display, bg="#e1e1e1")
        elif self.aktueller_listener == "rangier":
            self.taste_rangier_display, self.taste_rangier_code = display_name, scs_code
            self.btn_rangier.config(text=self.taste_rangier_display, bg="#e1e1e1")
        elif self.aktueller_listener == "notbremse":
            self.taste_notbremse_display, self.taste_notbremse_code = display_name, scs_code
            self.btn_not.config(text=self.taste_notbremse_display, bg="#e1e1e1")
            
        self.status_label.config(text=f"{self.txt['status_done']}{display_name}", fg="green")
        self.aktueller_listener = None


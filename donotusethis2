    # --- AUTOMATISCHER GITHUB-UPDATER MECHANISMUS ---
    def pruefe_auf_updates(self):
        if platform.system() != "Windows":
            return 

        try:
            url = f"https://github.com{self.github_user}/{self.github_repo}/releases/latest"
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
            
            with urllib.request.urlopen(req, timeout=3) as response:
                data = json.loads(response.read().decode())
                latest_tag = data.get("tag_name", self.aktuelle_version)
                
                if latest_tag != self.aktuelle_version:
                    assets = data.get("assets", [])
                    if assets and len(assets) > 0:
                        download_url = assets[0].get("browser_download_url")
                        
                        if download_url and messagebox.askyesno("Update verfügbar! 🚀", 
                            f"Eine neue Version ({latest_tag}) des RKS-Installers wurde gefunden!\n\n"
                            f"Deine Version: {self.aktuelle_version}\n"
                            f"Neueste Version: {latest_tag}\n\n"
                            "Möchtest du das Update jetzt vollautomatisch herunterladen und installieren?"):
                            
                            self.starte_selbst_update(download_url)
        except:
            pass 

    def starte_selbst_update(self, download_url):
        try:
            current_exe = sys.executable
            backup_exe = current_exe + ".old"
            
            if os.path.exists(backup_exe):
                os.remove(backup_exe)
            os.rename(current_exe, backup_exe)
            
            urllib.request.urlretrieve(download_url, current_exe)
            
            batch_cmd = f'ping 127.0.0.1 -n 2 > nul & del "{backup_exe}"'
            subprocess.Popen(f'cmd.exe /c {batch_cmd}', shell=True)
            subprocess.Popen([current_exe])
            
            self.root.destroy()
            sys.exit()
        except Exception as e:
            messagebox.showerror("Update-Fehler", f"Das automatische Update ist fehlgeschlagen: {str(e)}")


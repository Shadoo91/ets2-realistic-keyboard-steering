        selected_prof = self.prof_combo.get()
        if not selected_prof or selected_prof == self.txt["no_profiles"]:
            messagebox.showerror("Fehler", "Bitte wähle zuerst ein gültiges Profil aus!")
            return
            
        target_file = self.profile_dict[selected_prof]
        backup_file = target_file + ".bak"
        
        if os.path.exists(backup_file):
            if messagebox.askyesno("Deinstallieren", f"Möchtest du die RKS-Mod für das Profil '{selected_prof}' wirklich deinstallieren und das originale Backup wiederherstellen?"):

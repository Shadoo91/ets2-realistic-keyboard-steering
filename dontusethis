    def suche_profile(self):
        """
        Sucht vollautomatisch, plattformübergreifend und absolut ausfallsicher 
        nach ETS2/ATS-Profilen (Lokal, OneDrive, SteamCloud & Proton) [ex-1.3.4].
        """
        game_name = self.game_combo.get()
        app_id = "227300" if game_name == "Euro Truck Simulator 2" else "270880"
        home = os.path.expanduser("~")
        
        # Liste aller potenziellen Stammverzeichnisse für dieses Spiel
        basis_ordner_liste = []

        # 1. WINDOWS PFAD-ERMITTLUNG (INKL. ONEDRIVE & CO)
        if platform.system() == "Windows":
            try:
                import ctypes
                from ctypes import wintypes
                CSIDL_PERSONAL = 5       
                SHGFP_TYPE_CURRENT = 0
                buf = ctypes.create_unicode_buffer(wintypes.MAX_PATH)
                ctypes.windll.shell32.SHGetFolderPathW(None, CSIDL_PERSONAL, None, SHGFP_TYPE_CURRENT, buf)
                local_documents = buf.value
            except:
                local_documents = os.path.join(home, "Documents") 
                
            # Pfade zu den Dokumenten-Ordnern hinzufügen
            basis_ordner_liste.append(os.path.join(local_documents, game_name))
            basis_ordner_liste.append(os.path.join(os.environ.get("USERPROFILE", ""), "OneDrive", "Documents", game_name))
            
            # MASSEN-FALLBACK: Direkte Suche im Standard-Steam-Cloud Pfad auf Windows (Sehr häufig!)
            program_files = os.environ.get("ProgramFiles(x86)", "C:\\Program Files (x86)")
            steam_userdata = os.path.join(program_files, "Steam", "userdata")
            if os.path.exists(steam_userdata):
                for user_id in os.listdir(steam_userdata):
                    cloud_pfad = os.path.join(steam_userdata, user_id, app_id, "remote")
                    if os.path.exists(cloud_pfad):
                        basis_ordner_liste.append(cloud_pfad)

        # 2. LINUX PFAD-ERMITTLUNG (NATIV & PROTON-EMULATION)
        else:
            # Ihr funktionierender Linux-Pfad
            basis_ordner_liste.append(os.path.join(home, ".steam", "steam", "steamapps", "compatdata", app_id, "pfx", "drive_c", "users", "steamuser", "Documents", game_name))
            # Native Linux-Installation Fallback
            basis_ordner_liste.append(os.path.join(home, ".local", "share", game_name))
            # Flatpak-Steam Fallback
            basis_ordner_liste.append(os.path.join(home, ".var", "app", "com.valvesoftware.Steam", "data", "Steam", "steamapps", "compatdata", app_id, "pfx", "drive_c", "users", "steamuser", "Documents", game_name))

        # 3. PROFILE AUS ALLEN QUELLEN ERFASSEN
        self.profile_dict.clear()
        
        # Die 3 Ordner-Typen, in denen ETS2 Profile speichert [ex-1.3.4]
        profil_sub_ordner = ["profiles", "steam_profiles", "profiles_cloud"]

        for basis in basis_ordner_liste:
            if not basis or not os.path.exists(basis):
                continue
                
            # Falls wir direkt im Steam "remote"-Ordner gelandet sind, gibt es dort kein Sub-Verzeichnis
            ordner_zum_scannen = [basis] if os.path.basename(basis) == "remote" else [os.path.join(basis, sub) for sub in profil_sub_ordner]

            for s_dir in ordner_zum_scannen:
                if os.path.exists(s_dir) and os.path.isdir(s_dir):
                    for folder in os.listdir(s_dir):
                        profil_pfad = os.path.join(s_dir, folder)
                        if os.path.isdir(profil_pfad):
                            datei_pfad = os.path.join(profil_pfad, "controls.sii")
                            
                            # GHOST-FILTER: Nur aufnehmen, wenn die Datei wirklich existiert
                            if os.path.exists(datei_pfad) and os.path.isfile(datei_pfad):
                                try:
                                    readable_name = bytes.fromhex(folder).decode('utf-8', errors='ignore')
                                    # TEXT-BASIERTE PRÄFIXE: Verhindert Kästchen und falsche Abstände unter Windows
                                    if "steam" in s_dir.lower() or "remote" in s_dir.lower():
                                        prefix = "[Cloud]"
                                    else:
                                        prefix = "[Lokal]"
                                        
                                    display_str = f"{prefix} {readable_name} ({folder[:6]}...)"
                                    
                                    # Verhindert doppelte Einträge, falls ein Profil in mehreren Pfaden liegt
                                    if display_str not in self.profile_dict:
                                        self.profile_dict[display_str] = datei_pfad
                                except:
                                    pass
                        
        # 4. UI-DROPDOWN AKTUALISIEREN & STATUS AUSGEBEN
        if self.profile_dict:
            self.prof_combo.config(values=list(self.profile_dict.keys()))
            self.prof_combo.current(0)
            self.lbl_status_p2.config(text=f"✓ {len(self.profile_dict)} Profil(e) erfolgreich geladen.", fg="green")
        else:
            self.prof_combo.config(values=[self.txt["no_profiles"]])
            self.prof_combo.current(0)
            self.lbl_status_p2.config(text="⚠ Kein Profil gefunden. Bitte 'Manuelle Suche' nutzen!", fg="orange")

    def manuelle_dateiauswahl(self):
        """Ermöglicht das manuelle Heraussuchen der controls.sii und hebelt die Linux-Ordner-Versteckung aus."""
        # Standard-Startpfad für echtes Windows
        start_pfad = os.path.expanduser(r"~\Documents")
        
        # WINE-DETEKTION: Wenn wir unter Linux/Wine laufen, zwingen wir den Dialog direkt in den versteckten Pfad
        if "WINEPREFIX" in os.environ or platform.system() != "Windows":
            user_name = os.environ.get("USER", "unknown")
            game_name = self.game_combo.get()
            app_id = "227300" if game_name == "Euro Truck Simulator 2" else "270880"
            
            # Baut den direkten Pfad in die unsichtbare Steam-Flasche über Laufwerk Z:\
            test_wine_pfad = f"Z:\\home\\{user_name}\\.steam\\steam\\steamapps\\compatdata\\{app_id}\\pfx\\drive_c\\users\\steamuser\\Documents\\{game_name}"
            if os.path.exists(test_wine_pfad):
                start_pfad = test_wine_pfad
            else:
                # Fallback auf das normale Linux-Home über Z:\
                start_pfad = f"Z:\\home\\{user_name}"

        dateipfad = filedialog.askopenfilename(
            initialdir=start_pfad, # ZWINGT den Dialog, direkt im richtigen (versteckten) Ordner zu starten!
            title="Wähle deine aktive controls.sii aus",
            filetypes=[("ETS2 Steuerung", "controls.sii"), ("Alle Dateien", "*.*")]
        )
        
        if dateipfad:
            if os.path.basename(dateipfad) != "controls.sii":
                messagebox.showerror("Falsche Datei", "Bitte wählen Sie exakt die Datei 'controls.sii' aus!")
                return
                
            if os.path.getsize(dateipfad) <= 100:
                messagebox.showerror("Ghost-Datei", "Diese Datei enthält keine Daten (Ghost-Datei). Bitte wählen Sie die aktive Datei!")
                return
                
            if "userdata" in dateipfad.lower() or "remote" in dateipfad.lower():
                anzeige_name = "☁ [Steam Cloud] " + os.path.basename(os.path.dirname(os.path.dirname(dateipfad)))
            else:
                anzeige_name = "📂 [Manuell] " + os.path.basename(os.path.dirname(dateipfad))
                
            self.profile_dict[anzeige_name] = dateipfad
            
            # PRÄZISE KORREKTUR: Nutzt jetzt self.prof_combo anstatt self.combo_profil
            self.prof_combo['values'] = list(self.profile_dict.keys())
            self.prof_combo.set(anzeige_name)
            self.lbl_status_p2.config(text="✓ Externe controls.sii erfolgreich geladen!", fg="green")


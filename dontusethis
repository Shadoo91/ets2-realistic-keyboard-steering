import os
import sys
import shutil
import tkinter as tk
from tkinter import ttk, messagebox, filedialog

class ETS2SteeringInstaller:
    def __init__(self, root):
        self.root = root
        self.root.title("ETS2/ATS Realistic Keyboard Steering Installer")
        self.root.geometry("850x650")
        self.root.resizable(False, False)
        
        # Design & Farben (Dracula/Catppuccin Style)
        self.bg_main = "#1e1e2e"
        self.card_bg = "#252538"
        self.fg_text = "#cdd6f4"
        self.accent_blue = "#89b4fa"
        self.accent_green = "#a6e3a1"
        self.accent_red = "#f38ba8"
        
        self.root.configure(bg=self.bg_main)
        
        # Pfad-Variablen für die Logik
        self.aktueller_spiel_pfad = None
        self.aktuelle_profil_liste = []
        
        # Texte (Deutsch)
        self.txt = {
            "titel": "ETS2 / ATS - Realistische Tastaturlenkung v1.4",
            "info": (
                "Dieses Tool installiert die optimierten Lenkungseinstellungen für Euro Truck Simulator 2 "
                "oder American Truck Simulator. Es überschreibt die 'controls.sii' in deinem ausgewählten Profil.\n\n"
                "WICHTIG: Vor der Installation wird automatisch ein Backup deiner alten Datei im Profilordner "
                "erstellt (controls.sii.bak). So kannst du deine alten Einstellungen jederzeit wiederherstellen."
            ),
            "game_select": "1. Spiel wählen:",
            "profile_select": "2. Profil wählen:",
            "btn_install": "Modifikation installieren  🚀",
            "btn_uninstall": "Mod deinstallieren ❌",
            "status_idle": "Bereit für die Installation...",
            "success_title": "Installation erfolgreich!",
            "success_msg": (
                "Die realistische Tastaturlenkung wurde erfolgreich installiert!\n\n"
                "Vielen Dank, dass du dieses Projekt nutzt und unterstützt. Ich würde mich sehr über "
                "eine positive Bewertung oder konstruktive Kritik im Steam Workshop freuen. Viel Spaß! ;)"
            )
        }
        
        # --- UI AUFBAU ---
        self.config_frame = tk.Frame(self.root, padx=30, pady=20, bg=self.bg_main)
        self.config_frame.pack(fill="both", expand=True)
        
        tk.Label(self.config_frame, text=self.txt["titel"], font=("Arial", 15, "bold"), fg=self.accent_blue, bg=self.bg_main).pack(anchor="w", pady=(0, 10))
        tk.Label(self.config_frame, text=self.txt["info"], font=("Arial", 12), fg=self.fg_text, bg=self.bg_main, wraplength=760, justify="left").pack(anchor="w", pady=(0, 15))
        
        card_profile = tk.Frame(self.config_frame, bg=self.card_bg, bd=1, relief="solid", padx=15, pady=15)
        card_profile.pack(fill="x", pady=(0, 15))
        
        # 1. Spielauswahl-Zeile
        game_frame = tk.Frame(card_profile, bg=self.card_bg)
        game_frame.pack(fill="x", pady=5)
        tk.Label(game_frame, text=self.txt["game_select"], font=("Arial", 12, "bold"), fg=self.fg_text, bg=self.card_bg, width=15, anchor="w").pack(side="left")
        self.game_combo = ttk.Combobox(game_frame, values=["Euro Truck Simulator 2", "American Truck Simulator"], state="readonly", width=30, font=("Arial", 11))
        self.game_combo.current(0)
        self.game_combo.pack(side="left")
        self.game_combo.bind("<<ComboboxSelected>>", lambda e: self.suche_profile())
        
        # 2. Profilauswahl-Zeile mit manuellem Such-Button
        prof_frame = tk.Frame(card_profile, bg=self.card_bg)
        prof_frame.pack(fill="x", pady=5)
        tk.Label(prof_frame, text=self.txt["profile_select"], font=("Arial", 12, "bold"), fg=self.fg_text, bg=self.card_bg, width=15, anchor="w").pack(side="left")
        self.prof_combo = ttk.Combobox(prof_frame, state="readonly", width=30, font=("Arial", 11))
        self.prof_combo.pack(side="left")
        
        self.btn_browse = tk.Button(prof_frame, text="📁 Pfad wählen...", command=self.manueller_pfad_waehlen, font=("Arial", 10), bg="#e0e0e0", fg="black", relief="groove")
        self.btn_browse.pack(side="left", padx=10)
        
        self.btn_uninstall = tk.Button(prof_frame, text=self.txt["btn_uninstall"], bg=self.accent_red, fg="white", font=("Arial", 10, "bold"), relief="flat", padx=10, command=self.deinstalliere_mod)
        self.btn_uninstall.pack(side="right", padx=5)
        

    def check_for_updates(self):
        """Prüft auf GitHub nach Updates und installiert sie vollautomatisch."""
        import urllib.request
        import json
        import subprocess
        
        CURRENT_VERSION = "1.10.2"
        VERSION_URL = "https://githubusercontent.com"
        EXE_URL = "https://githubusercontent.com"
        
        try:
            with urllib.request.urlopen(VERSION_URL, timeout=4) as response:
                data = json.loads(response.read().decode())
                latest_version = data.get("version", CURRENT_VERSION)
                
                if latest_version != CURRENT_VERSION:
                    antwort = messagebox.askyesno(
                        "Update verfügbar! 🚀", 
                        f"Eine neue Version ({latest_version}) ist verfügbar!\n\nMöchtest du den Hotfix jetzt automatisch installieren und neu starten?"
                    )
                    if not antwort:
                        return

                    self.status_label.config(text="Lade Update herunter...", fg=self.accent_blue)
                    self.root.update()

                    current_exe = sys.argv[0]
                    exe_dir = os.path.dirname(os.path.abspath(current_exe))
                    new_exe_tmp = os.path.join(exe_dir, "update_tmp.exe")

                    urllib.request.urlretrieve(EXE_URL, new_exe_tmp)

                    batch_path = os.path.join(exe_dir, "updater.bat")
                    with open(batch_path, "w") as b:
                        b.write("@echo off\n")
                        b.write("timeout /t 1 /nobreak > nul\n")
                        b.write(f'move /y "{new_exe_tmp}" "{current_exe}"\n')
                        b.write(f'start "" "{current_exe}"\n')
                        b.write(f'del "{batch_path}"\n')

                    subprocess.Popen([batch_path], shell=True)
                    self.root.destroy()
                    sys.exit()
        except Exception:
            pass

    def lese_profile_aus_ordner(self, profiles_dir):
        """Scannt den Zielordner und filtert OneDrive-Geisterpfade aus."""
        gueltige_profile = []
        if not os.path.isdir(profiles_dir):
            return gueltige_profile

        for folder in os.listdir(profiles_dir):
            vollstaendiger_pfad = os.path.join(profiles_dir, folder)
            controls_datei = os.path.join(vollstaendiger_pfad, "controls.sii")
            
            # WICHTIGER FIX: os.path.isfile stellt sicher, dass die Datei real existiert
            if os.path.isdir(vollstaendiger_pfad) and os.path.isfile(controls_datei):
                try:
                    lesbarer_name = bytes.fromhex(folder).decode('utf-8', errors='ignore')
                    display_name = f"{lesbarer_name} ({folder})" if lesbarer_name.strip() else folder
                except Exception:
                    display_name = folder
                
                gueltige_profile.append({"folder": folder, "name": display_name})
                
        return gueltige_profile

    def suche_profile(self):
        """Versucht automatisch den ETS2/ATS Ordner in den Dokumenten zu finden."""
        spiel = self.game_combo.get()
        user_docs = os.path.expanduser("~/Documents")
        
        self.aktueller_spiel_pfad = os.path.join(user_docs, spiel)
        profiles_path = os.path.join(self.aktueller_spiel_pfad, "profiles")
        
        self.aktuelle_profil_liste = self.lese_profile_aus_ordner(profiles_path)
        
        if self.aktuelle_profil_liste:
            anzuzeigende_namen = [p["name"] for p in self.aktuelle_profil_liste]
            self.prof_combo["values"] = anzuzeigende_namen
            self.prof_combo.current(0)
            self.status_label.config(text=f"Automatisch {len(self.aktuelle_profil_liste)} echte Profile gefunden.", fg=self.accent_green)
        else:
            self.prof_combo["values"] = []
            self.prof_combo.set("")
            self.status_label.config(text="Keine Profile automatisch gefunden. Bitte Pfad manuell wählen!", fg=self.accent_red)

    def manueller_pfad_waehlen(self):
        """Erlaubt dem User, den Pfad selbst auszuwählen."""
        initial_dir = os.path.expanduser("~/Documents")
        gewaehlter_pfad = filedialog.askdirectory(title="Wähle den ETS2/ATS Hauptordner aus", initialdir=initial_dir)
        
        if not gewaehlter_pfad:
            return

        if os.path.basename(gewaehlter_pfad).lower() == "profiles":
            base_dir = os.path.dirname(gewaehlter_pfad)
        else:
            base_dir = gewaehlter_pfad

        self.aktueller_spiel_pfad = base_dir
        profiles_path = os.path.join(base_dir, "profiles")

        if not os.path.isdir(profiles_path):
            messagebox.showerror("Ordner ungültig", f"Unter:\n{base_dir}\nwurde kein 'profiles'-Ordner gefunden!")
            return

        self.aktuelle_profil_liste = self.lese_profile_aus_ordner(profiles_path)

        if self.aktuelle_profil_liste:
            anzuzeigende_namen = [p["name"] for p in self.aktuelle_profil_liste]
            self.prof_combo["values"] = anzuzeigende_namen
            self.prof_combo.current(0)
            messagebox.showinfo("Erfolg", f"Es wurden {len(self.aktuelle_profil_liste)} echte Profile gefunden!")
            self.status_label.config(text="Manueller Pfad aktiv.", fg=self.accent_green)
        else:
            self.prof_combo["values"] = []
            self.prof_combo.set("")
            messagebox.showwarning("Keine Profile", "Ordner existiert, enthält aber keine echten Profile mit controls.sii.")

    def hole_ausgewaehlten_profil_ordner(self):
        """Gibt den exakten Ordnernamen (Hex) des Profils zurück."""
        ausgewaehlter_index = self.prof_combo.current()
        if ausgewaehlter_index == -1:
            return None
        return self.aktuelle_profil_liste[ausgewaehlter_index]["folder"]

    def installiere_mod(self):
        """
        Prüft das Workshop-Abo auf allen Laufwerken. Blockiert bei Fehlen 
        und zwingt zur Akzeptanz der Terms vor der Installation.
        """
        import webbrowser
        
        # 1. DYNAMISCHER WORKSHOP ABO SCAN
        spiel_name = self.game_combo.get()
        # ETS2 hat die App-ID 22730, ATS hat 270880
        app_id = "22730" if "Euro Truck" in spiel_name else "270880"
        workshop_id = "3727705125"  # Deine Mod-ID
        
        # Wir prüfen alle gängigen Laufwerke (C bis G), falls Steam nicht auf C liegt
        laufwerke = ["C", "D", "E", "F", "G"]
        workshop_gefunden = False
        
        for lw in laufwerke:
            test_pfad = f"{lw}:\\Program Files (x86)\\Steam\\steamapps\\workshop\\content\\{app_id}\\{workshop_id}"
            test_pfad_alt = f"{lw}:\\SteamLibrary\\steamapps\\workshop\\content\\{app_id}\\{workshop_id}"
            
            if os.path.exists(test_pfad) or os.path.exists(test_pfad_alt):
                workshop_gefunden = True
                break

        # HARD LOCK: Wenn die Mod nicht gefunden wurde, wird abgebrochen
        if not workshop_gefunden:
            self.status_label.config(text="Fehler: Mod nicht im Workshop abonniert!", fg=self.accent_red)
            
            # Fehlermeldung mit Workshop-Link anzeigen
            workshop_link = f"https://steamcommunity.com/sharedfiles/filedetails/?id={workshop_id}"
            antwort = messagebox.askyesno(
                "Abonnement fehlt!", 
                f"Es wurde kein aktives Abo für diese Mod im Steam Workshop gefunden.\n\n"
                f"Die Installation wurde blockiert.\n\nMöchtest du die Workshop-Seite jetzt öffnen, um die Mod zu abonnieren?"
            )
            if antwort:
                webbrowser.open(workshop_link)
            return

        # 2. TERMS / README ABFRAGE (Zwingend vor Installation)
        terms_text = (
            "NUTZUNGSBEDINGUNGEN & README:\n\n"
            "1. Diese Modifikation verändert deine Steuerungseinstellungen für ein realistischeres Fahrgefühl.\n"
            "2. Vor der Installation wird ein Backup (controls.sii.bak) angelegt.\n"
            "3. Der Entwickler übernimmt keine Haftung für beschädigte Spielstände.\n\n"
            "Möchtest du diese Bedingungen akzeptieren und mit der Installation fortfahren?"
        )
        akzeptiert = messagebox.askyesno("Nutzungsbedingungen akzeptieren", terms_text)
        if not akzeptiert:
            self.status_label.config(text="Installation abgebrochen: Bedingungen nicht akzeptiert.", fg=self.accent_red)
            return

        profil_folder = self.hole_ausgewaehlten_profil_ordner()
        if not profil_folder or not self.aktueller_spiel_pfad:
            messagebox.showerror("Fehler", "Bitte wähle zuerst ein gültiges Profil aus!")
            return
            
        ziel_datei = os.path.join(self.aktueller_spiel_pfad, "profiles", profil_folder, "controls.sii")
        backup_datei = ziel_datei + ".bak"
        
        if not os.path.isfile(ziel_datei):
            messagebox.showerror("Fehler", "Die controls.sii dieses Profils existiert nicht physisch!")
            return

        try:
            # 3. MANUELLE BACKUP ABFRAGE
            if os.path.exists(backup_datei):
                antwort_backup = messagebox.askyesno(
                    "Backup existiert bereits", 
                    "Es wurde bereits ein Backup (controls.sii.bak) gefunden.\n"
                    "Möchtest du dieses Backup überschreiben und die Mod neu installieren?"
                )
                if not antwort_backup:
                    return
            
            # Erstellt oder überschreibt das Backup erst nach der Bestätigung
            shutil.copy2(ziel_datei, backup_datei)
                
            # 4. MOD INJEKTIONSLOGIK (OneDrive-Sicher)
            with open(ziel_datei, "r", encoding="utf-8", errors="ignore") as f:
                zeilen = f.readlines()
                
            neue_zeilen = []
            mod_daten = {
                'device keyboard': 'config_lines = "device keyboard `di8.keyboard`"',
                'mix steering': 'config_lines = "mix steering `dsteering - deadzone(-sel(c_jisteer, -sys.steering, j_steering), c_jisteer_dz) * c_jisteer_sens`"',
                'mix steerleft': 'config_lines = "mix steerleft `keyboard.a?0 | keyboard.larrow?0`"',
                'mix steerright': 'config_lines = "mix steerright `keyboard.d?0 | keyboard.rarrow?0`"'
            }
            
            for zeile in zeilen:
                ersetzt = False
                for key, value in mod_daten.items():
                    if key in zeile:
                        neue_zeilen.append(value + "\n")
                        ersetzt = True
                        break
                if not ersetzt:
                    neue_zeilen.append(zeile)
                    
            with open(ziel_datei, "w", encoding="utf-8") as f:
                f.writelines(neue_zeilen)
                
            messagebox.showinfo(self.txt["success_title"], self.txt["success_msg"])
            self.status_label.config(text="Modifikation erfolgreich installiert!", fg=self.accent_green)
            
        except Exception as e:
            messagebox.showerror("Fehler", f"Fehler bei der Installation:\n{str(e)}")


    def deinstalliere_mod(self):
        """Stelt das automatische Backup wieder her."""
        profil_folder = self.hole_ausgewaehlten_profil_ordner()
        if not profil_folder or not self.aktueller_spiel_pfad:
            messagebox.showerror("Fehler", "Bitte wähle zuerst ein gültiges Profil aus!")
            return
            
        ziel_datei = os.path.join(self.aktueller_spiel_pfad, "profiles", profil_folder, "controls.sii")
        backup_datei = ziel_datei + ".bak"
        
        if os.path.isfile(backup_datei):
            try:
                shutil.copy2(backup_datei, ziel_datei)
                messagebox.showinfo("Deinstalliert", "Das Backup wurde erfolgreich wiederhergestellt!")
                self.status_label.config(text="Backup wiederhergestellt.", fg=self.accent_blue)
            except Exception as e:
                messagebox.showerror("Fehler", f"Fehler beim Wiederherstellen:\n{str(e)}")
        else:
            messagebox.showwarning("Kein Backup", "Es wurde kein Backup für dieses Profil gefunden.")


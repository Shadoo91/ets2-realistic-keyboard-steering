                os.chmod(target_file, 0o666)

            if not os.path.exists(backup_file):
                shutil.copyfile(target_file, backup_file)
                if os.path.exists(backup_file):
                    os.chmod(backup_file, stat.S_IWRITE)
                
            with open(target_file, "r", encoding="utf-8", errors="ignore") as f:
                lines = f.readlines()
                
            T = self.taste_turbo_code
            R = self.taste_rangier_code
            N = self.taste_notbremse_code
            
            rks_formeln = [
                f'mix dsteerleft `keyboard.a?0`',
                f'mix dsteerright `keyboard.d?0`',
                f'mix dsteering `(keyboard.a?0 - keyboard.d?0) * (0.30 + ({T} * (0.60 - (keyboard.s?0 * 0.25)))) * (1.00 + (keyboard.s?0 * {N} * 1.20)) * (c_steer_func * (4.2 - steering_speed_coef))`',
                f'mix steering `(dsteering * (1.00 - c_steer_func)) + (({R}) * (keyboard.a?0 - keyboard.d?0) * 0.35)`',
                f'mix msteering `-mouse.rel_position.x?0 * c_msens`',
                f'mix mpedals `mouse.rel_position.y?0 * c_msens`',
                f'mix dforward `0`',
                f'mix dbackward `0`',
                f'mix aforward `((keyboard.w?0 * 0.35) + ({N} * 0.55)) * (! keyboard.s?0)`',
                f'mix abackward `keyboard.s?0 * (0.10 + ({T} * 0.35) + ({N} * 1.00))`',
                f'mix forward `aforward`',
                f'mix backward `abackward`'
            ]

            # --- CACHE-FREIE & SCHNITTSTELLENGENAUE IN-PLACE-REPARATUR ---
            # Wir erzwingen das physische Neueinlesen der Datei, um RAM-Leichen zu verhindern
            try:
                with open(target_file, "r", encoding="utf-8", errors="ignore") as f_retry:
                    lines = f_retry.readlines()
            except:
                pass

            bereinigte_lines = []
            max_index = 320
            
            # Das exakte Mapping Ihrer RKS-Mod-Formeln
            formel_mapping = {
                "mix dsteerleft": f"mix dsteerleft `keyboard.a?0`",
                "mix dsteerright": f"mix dsteerright `keyboard.d?0`",
                "mix dsteering": f"mix dsteering `(keyboard.a?0 - keyboard.d?0) * (0.30 + ({T} * (0.60 - (keyboard.s?0 * 0.25)))) * (1.00 + (keyboard.s?0 * {N} * 1.20)) * (c_steer_func * (4.2 - steering_speed_coef))`",
                "mix steering": f"mix steering `(dsteering * (1.00 - c_steer_func)) + (({R}) * (keyboard.a?0 - keyboard.d?0) * 0.35)`",
                "mix msteering": f"mix msteering `-mouse.rel_position.x?0 * c_msens`",
                "mix mpedals": f"mix mpedals `mouse.rel_position.y?0 * c_msens`",
                "mix dforward": f"mix dforward `0`",
                "mix dbackward": f"mix dbackward `0`",
                "mix aforward": f"mix aforward `((keyboard.w?0 * 0.35) + ({N} * 0.55)) * (! keyboard.s?0)`",
                "mix abackward": f"mix abackward `keyboard.s?0 * (0.10 + ({T} * 0.35) + ({N} * 1.00))`",
                "mix forward": f"mix forward `aforward`",
                "mix backward": f"mix backward `abackward`"
            }
            
            # Tracker, welche Keys erfolgreich im originalen Bereich (oben) ersetzt wurden
            oben_ersetzt = {x: False for x in formel_mapping.keys()}

            for line in lines:
                if "config_lines[" in line:
                    try:
                        # Holt die reine numerische ID der Zeile aus den eckigen Klammern
                        # Das fängt jeden Fehler ab, falls parts eine Liste ist!
                        idx_part = line.split("config_lines[")[1].split("]")[0]
                        line_idx = int(idx_part)
                        max_index = max(max_index, line_idx)
                    except: 
                        line_idx = 999 # Fallback für beschädigte Indizes
                else:
                    line_idx = 999

                # RADIKALER UNTEN-ANHÄNG-SCHUTZ:
                # Wenn eine Mod-Zeile eine ID größer als 400 hat, ist sie eine "Anhäng-Leiche".
                # Diese wird hier im Live-View knallhart gelöscht!
                if line_idx > 400 and any(f"{x} " in line for x in formel_mapping.keys()):
                    continue

                # ECHTER IN-PLACE TAUSCH (NUR IM VANILLA-BEREICH OBEN)
                getauscht = False
                if line_idx <= 400:
                    for key, formel in formel_mapping.items():
                        if f' {key} `' in line or f' "{key} `' in line or f' {key} "' in line:
                            try:
                                # Spaltet die Zeile exakt vor dem eigentlichen Inhalt auf
                                # Behält config_lines[334]: " exakt bei und tauscht nur die Formel!
                                prefix = line.split(' "')[0]
                                line = f'{prefix} "{formel}"\n'
                                oben_ersetzt[key] = True
                                getauscht = True
                                break
                            except: 
                                pass
                
                if getauscht:
                    bereinigte_lines.append(line)
                    continue

                bereinigte_lines.append(line)
            
            # SELBSTHEILUNG: Falls eine Zeile oben komplett gelöscht war und fehlt
            reparatur_block = []
            # Wir setzen die fehlenden Zeilen mit fortlaufender ID ab 330 ein, falls sie oben fehlten
            reparatur_idx = 330
            for key, formel in formel_mapping.items():
                if not oben_ersetzt[key]:
                    reparatur_block.append(f' config_lines[{reparatur_idx}]: "{formel}"\n')
                reparatur_idx += 1

            # Sucht die Position der schließenden Profil-Klammer '}' für den Notfall
            klammer_index = -1
            for idx in range(len(bereinigte_lines) - 1, -1, -1):
                if "}" in bereinigte_lines[idx]:
                    klammer_index = idx
                    break
            
            # Fügt die fehlenden Zeilen als geschlossenen Block ein, NUR wenn sie oben gefehlt haben
            if reparatur_block:
                # Wir suchen im Array nach der Zeile 329, um es genau dort einzubetten, statt unten!
                einfuege_punkt = klammer_index
                for idx, bline in enumerate(bereinigte_lines):
                    if "config_lines[329]" in bline:
                        einfuege_punkt = idx + 1
                        break
                
                if einfuege_punkt != -1:
                    bereinigte_lines[einfuege_punkt:einfuege_punkt] = reparatur_block

            # SCHREIBEN ERZWINGEN (Ohne Caching-Verzögerung)
            with open(target_file, "w", encoding="utf-8") as f:
                f.writelines(bereinigte_lines)
                f.flush()

            # UNBESTECHLICHE VERIFIKATION
            try:
                with open(target_file, "r", encoding="utf-8", errors="ignore") as f_check:
                    if "mix dsteering" in f_check.read():
                        ist_erfolgreich = True
            except:
                ist_erfolgreich = False
                
            fehler_details = "Keine"

        except Exception as e:
            ist_erfolgreich = False
            fehler_details = str(e)

        # OUTPUT ANZEIGE (Präzise Pfad-Verifikation für den User)
        if ist_erfolgreich:
            tk.Label(self.end_frame, text=self.txt["status_success"], font=("Arial", 14, "bold"), fg="green", bg=self.bg_main).pack(anchor="w", pady=(40, 10))
            
            # Zeigt den exakten Ordner an, in den Python gerade geschrieben hat
            speicher_ordner = os.path.dirname(target_file)
            tk.Label(self.end_frame, text=f"Erfolgreich modifiziert in:\n➔ {speicher_ordner}", font=("Arial", 10, "bold"), fg="#3498db", bg=self.bg_main, justify="left", wraplength=700).pack(anchor="w", pady=(0, 10))
            
            tk.Label(self.end_frame, text="Die Dateien deines gewählten Profils wurden erfolgreich modifiziert. Viel Spaß beim Fahren!", font=("Arial", 12), fg=self.fg_text, bg=self.bg_main).pack(anchor="w", pady=(0, 20))
        else:
            tk.Label(self.end_frame, text=self.txt["status_failed"], font=("Arial", 14, "bold"), fg="red", bg=self.bg_main).pack(anchor="w", pady=(40, 5))
            # NEU: Zeigt dem User jetzt exakt an, WARUM Python abgestürzt ist, statt pauschal ATS zu beschuldigen
            tk.Label(self.end_frame, text=f"Fehler beim Schreiben: {fehler_details}\nBitte stelle sicher, dass ETS2/ATS geschlossen sind und versuche es erneut!", font=("Arial", 11), fg=self.fg_text, bg=self.bg_main, justify="left", wraplength=700).pack(anchor="w", pady=(0, 20))

        line_end = tk.Frame(self.end_frame, height=2, bg="#dddddd")
        line_end.pack(fill="x", pady=10)

        lbl_danke = tk.Label(self.end_frame, text=(
            "Vielen Dank, dass du dieses Projekt nutzt und unterstützt!\n"
            "Ich würde mich sehr über eine positive Bewertung oder konstruktive Kritik im Steam Workshop freuen.\n\n"
            "Viel Spaß und gute Fahrt wünscht dir Shadoo91! 🚚💨 ;)"
        ), font=("Arial", 12, "italic"), fg="#333333", bg=self.bg_main, justify="center", wraplength=700)
        lbl_danke.pack(anchor="center", pady=20)

        self.btn_close = tk.Button(self.end_frame, text=f"{self.txt['btn_close']} (2s)", width=15, height=2, bg="#e1e1e1", fg="#888888", font=("Arial", 11, "bold"), state="disabled", relief="flat", command=self.root.destroy)
        self.btn_close.pack(side="bottom", anchor="e", pady=20)

        self.root.after(2000, self.aktiviere_schliessen_button)


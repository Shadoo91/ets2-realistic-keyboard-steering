    # --- AUTOMATISCHER GITHUB-UPDATER MECHANISMUS ---
    def pruefe_updates(self):
        """Prüft über die GitHub-API nach Updates unter Verwendung der Klassen-Variablen."""
        # Baut den API-Link dynamisch aus Ihren Variablen zusammen
        api_url = f"https://api.github.com/repos/{self.github_user}/{self.github_repo}/releases/latest"
        
        try:
            # Fragt GitHub mit einem Timeout von 3 Sekunden ab (verhindert GUI-Freeze)
            response = requests.get(api_url, timeout=3)
            if response.status_code == 200:
                release_data = response.json()
                neueste_version = release_data.get("tag_name", self.aktuelle_version)
                
                # PRÄZISE DETEKTION DER DIREKTEN DOWNLOAD-URL DER .EXE
                assets = release_data.get("assets", [])
                download_url = ""
                
                if assets:
                    # Sucht gezielt nach der fertigen ausführbaren Datei im Release
                    for asset in assets:
                        if asset.get("name", "").endswith(".exe") or asset.get("name", "").endswith(".py"):
                            download_url = asset.get("browser_download_url", "")
                            break
                
                # Falls kein spezifisches Asset gefunden wurde, nutzen wir die allgemeine URL als Fallback
                if not download_url:
                    download_url = release_data.get("html_url", "")
                
                # Vergleicht das GitHub-Tag mit Ihrer self.aktuelle_version ("v1.10.2 (Hotfix)")
                if neueste_version != self.aktuelle_version:
                    antwort = messagebox.askyesno(
                        "Update verfügbar! 🚀", 
                        f"Eine neuere Version ({neueste_version}) des Installers ist verfügbar!\n"
                        f"Deine aktuelle Version: {self.aktuelle_version}\n\n"
                        "Möchtest du das automatische Update jetzt starten?\n"
                        "(Das Programm lädt die neue Version herunter und startet sich vollautomatisch neu!)"
                    )
                    
                    # PRÄZISE BEFEHLS-WEICHE: Startet das echte Selbst-Update anstatt nur den Browser zu öffnen
                    if antwort and download_url:
                        self.starte_selbst_update(download_url)
        except Exception:
            # Bei Offline-Modus oder GitHub-Störung läuft das Programm lautlos weiter
            pass

    def starte_selbst_update(self, download_url):
        try:
            current_exe = sys.executable
            backup_exe = current_exe + ".old"
            
            # Löscht ein eventuell verbliebenes altes Backup
            if os.path.exists(backup_exe):
                os.remove(backup_exe)
                
            # Benennt die aktuell laufende Datei um (wird vom OS im RAM gehalten)
            os.rename(current_exe, backup_exe)
            
            # Lädt die neue Version direkt an den alten Platz herunter
            urllib.request.urlretrieve(download_url, current_exe)
            
            # PLATTFORM-WEICHE FÜR DEN HINTERGRUND-REINIGER
            if platform.system() == "Windows" and "WINEPREFIX" not in os.environ:
                # Ihr originaler, perfekt funktionierender Windows-Befehl
                batch_cmd = f'ping 127.0.0.1 -n 2 > nul & del "{backup_exe}"'
                subprocess.Popen(f'cmd.exe /c {batch_cmd}', shell=True)
            else:
                # LINUX LOGIK: Nutzt die Standard-Shell, wartet 2 Sekunden und löscht das Backup
                os.chmod(current_exe, 0o755)  # Macht die neue Datei unter Linux sofort ausführbar!
                linux_cmd = f'sleep 2 && rm -f "{backup_exe}"'
                subprocess.Popen(['/bin/sh', '-c', linux_cmd])
            
            # Startet die neue Version im Hintergrund
            subprocess.Popen([current_exe])
            
            # Schließt den alten Installer sofort, damit er im Ordner freigegeben wird
            self.root.destroy()
            sys.exit()
            
        except Exception as e:
            messagebox.showerror("Update-Fehler", f"Das automatische Update ist fehlgeschlagen: {str(e)}")


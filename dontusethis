        self.status_label.pack(side="bottom", fill="x")
        
        # Erste automatische Suche beim Start ausführen
        self.suche_profile()

    def lese_profile_aus_ordner(self, profiles_dir):
        """
        Scannt den Zielordner und filtert OneDrive-Geisterpfade aus.
        Gibt NUR Profile zurück, bei denen die controls.sii physisch existiert.
        """
        gueltige_profile = []
        if not os.path.isdir(profiles_dir):
            return gueltige_profile

        for folder in os.listdir(profiles_dir):
            vollstaendiger_pfad = os.path.join(profiles_dir, folder)
            controls_datei = os.path.join(vollstaendiger_pfad, "controls.sii")
            
            # OS.PATH.ISFILE FILTER: Verhindert leere OneDrive "Ghost"-Profile
            if os.path.isdir(vollstaendiger_pfad) and os.path.isfile(controls_datei):
                try:
                    lesbarer_name = bytes.fromhex(folder).decode('utf-8', errors='ignore')
                    display_name = f"{lesbarer_name} ({folder})" if lesbarer_name.strip() else folder
                except Exception:
                    display_name = folder
                
                gueltige_profile.append({"folder": folder, "name": display_name})
                
        return gueltige_profile

    def suche_profile(self):
        """Versucht automatisch den ETS2/ATS Ordner in den Dokumenten zu finden."""
        spiel = self.game_combo.get()
        user_docs = os.path.expanduser("~/Documents")
        
        # Standard-Pfade zusammenbauen
        self.aktueller_spiel_pfad = os.path.join(user_docs, spiel)
        profiles_path = os.path.join(self.aktueller_spiel_pfad, "profiles")
        
        self.aktuelle_profil_liste = self.lese_profile_aus_ordner(profiles_path)
        
        if self.aktuelle_profil_liste:
            anzuzeigende_namen = [p["name"] for p in self.aktuelle_profil_liste]
            self.prof_combo["values"] = anzuzeigende_namen
            self.prof_combo.current(0)
            self.status_label.config(text=f"Automatisch {len(self.aktuelle_profil_liste)} echte Profile gefunden.", fg=self.accent_green)
        else:
            self.prof_combo["values"] = []
            self.prof_combo.set("")
            self.status_label.config(text="Keine Profile automatisch gefunden. Bitte Pfad manuell wählen!", fg=self.accent_red)

    def manueller_pfad_waehlen(self):
        """Erlaubt dem User, den Pfad selbst auszuwählen falls OneDrive blockiert."""
        initial_dir = os.path.expanduser("~/Documents")
        gewaehlter_pfad = filedialog.askdirectory(title="Wähle den ETS2/ATS Hauptordner aus", initialdir=initial_dir)
        
        if not gewaehlter_pfad:
            return

        if os.path.basename(gewaehlter_pfad).lower() == "profiles":
            base_dir = os.path.dirname(gewaehlter_pfad)
        else:
            base_dir = gewaehlter_pfad

        self.aktueller_spiel_pfad = base_dir
        profiles_path = os.path.join(base_dir, "profiles")

        if not os.path.isdir(profiles_path):
            messagebox.showerror("Ordner ungültig", f"Unter:\n{base_dir}\nwurde kein 'profiles'-Ordner gefunden!")
            return

        self.aktuelle_profil_liste = self.lese_profile_aus_ordner(profiles_path)

        if self.aktuelle_profil_liste:
            anzuzeigende_namen = [p["name"] for p in self.aktuelle_profil_liste]
            self.prof_combo["values"] = anzuzeigende_namen
            self.prof_combo.current(0)
            messagebox.showinfo("Erfolg", f"Es wurden {len(self.aktuelle_profil_liste)} echte Profile gefunden!")
            self.status_label.config(text="Manueller Pfad aktiv.", fg=self.accent_green)
        else:
            self.prof_combo["values"] = []
            self.prof_combo.set("")
            messagebox.showwarning("Keine Profile", "Ordner existiert, enthält aber keine echten Profile mit controls.sii.")

    def hole_ausgewaehlten_profil_ordner(self):
        """Gibt den exakten Ordnernamen (Hex) des aktuell ausgewählten Profils zurück."""
        ausgewaehlter_index = self.prof_combo.current()
        if ausgewaehlter_index == -1:
            return None
        return self.aktuelle_profil_liste[ausgewaehlter_index]["folder"]

    def installiere_mod(self):
        """Erstellt ein Backup und schleust deine Mod-Zeilen in die controls.sii ein."""
        profil_folder = self.hole_ausgewaehlten_profil_ordner()
        if not profil_folder or not self.aktueller_spiel_pfad:
            messagebox.showerror("Fehler", "Bitte wähle zuerst ein gültiges Profil aus!")
            return
            
        ziel_datei = os.path.join(self.aktueller_spiel_pfad, "profiles", profil_folder, "controls.sii")
        backup_datei = ziel_datei + ".bak"
        
        if not os.path.isfile(ziel_datei):
            messagebox.showerror("Fehler", "Die controls.sii dieses Profils existiert nicht physisch!")
            return

        try:
            # Backup erstellen falls noch keines existiert
            if not os.path.exists(backup_datei):
                shutil.copy2(ziel_datei, backup_datei)
                
            # --- MOD INJEKTIONSLOGIK ---
            with open(ziel_datei, "r", encoding="utf-8", errors="ignore") as f:
                zeilen = f.readlines()
                
            neue_zeilen = []
            mod_daten = {
                'config_lines = "device keyboard': 'config_lines = "device keyboard `di8.keyboard`"',
                'config_lines = "mix steering': 'config_lines = "mix steering `dsteering - deadzone(-sel(c_jisteer, -sys.steering, j_steering), c_jisteer_dz) * c_jisteer_sens`"',
                'config_lines = "mix steerleft': 'config_lines = "mix steerleft `keyboard.a?0 | keyboard.larrow?0`"',
                'config_lines = "mix steerright': 'config_lines = "mix steerright `keyboard.d?0 | keyboard.rarrow?0`"'
            }
            
            for zeile in zeilen:
                ersetzt = False
                for key, value in mod_daten.items():
                    if zeile.strip().startswith(key):
                        neue_zeilen.append(value + "\n")
                        ersetzt = True
                        break
                if not ersetzt:
                    neue_zeilen.append(zeile)
                    
            with open(ziel_datei, "w", encoding="utf-8") as f:
                f.writelines(neue_zeilen)
                
            messagebox.showinfo(self.txt["success_title"], self.txt["success_msg"])
            self.status_label.config(text="Modifikation erfolgreich installiert!", fg=self.accent_green)
            
        except Exception as e:
            messagebox.showerror("Fehler", f"Fehler bei der Installation:\n{str(e)}")

    def deinstalliere_mod(self):
        """Stellt das automatische Backup wieder her."""
        profil_folder = self.hole_ausgewaehlten_profil_ordner()
        if not profil_folder or not self.aktueller_spiel_pfad:
            messagebox.showerror("Fehler", "Bitte wähle zuerst ein gültiges Profil aus!")
            return
            
        ziel_datei = os.path.join(self.aktueller_spiel_pfad, "profiles", profil_folder, "controls.sii")
        backup_datei = ziel_datei + ".bak"
        
        if os.path.isfile(backup_datei):
            try:
                shutil.copy2(backup_datei, ziel_datei)
                messagebox.showinfo("Deinstalliert", "Das Backup wurde erfolgreich wiederhergestellt!")
                self.status_label.config(text="Backup wiederhergestellt.", fg=self.accent_blue)
            except Exception as e:
                messagebox.showerror("Fehler", f"Fehler beim Wiederherstellen:\n{str(e)}")
        else:
            messagebox.showwarning("Kein Backup", "Es wurde kein Backup (controls.sii.bak) für dieses Profil gefunden.")

if __name__ == "__main__":
    root = tk.Tk()
    app = ETS2SteeringInstaller(root)
    root.mainloop()

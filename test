    # --- DEINE ORIGINALE PROFILSUCHE (ERWEITERT UM DEN MANUELLEN PARAMETER) ---
    def suche_profile(self, alternativer_pfad=None):
        if not hasattr(self, 'game_combo'): 
            return # Sicherheitsabfrage falls Aufruf vor UI-Init erfolgt
            
        game_name = self.game_combo.get()
        home = os.path.expanduser("~")
        base_path = None
        
        # Wenn über den neuen Button gesucht wurde, erzwingen wir diesen als Pfad
        if alternativer_pfad:
            base_path = alternativer_pfad
        else:
            # Deine originale vollautomatische Erkennungslogik läuft unberührt weiter:
            if platform.system() == "Windows":
                try:
                    import ctypes
                    from ctypes import wintypes
                    CSIDL_PERSONAL = 5       
                    SHGFP_TYPE_CURRENT = 0
                    buf = ctypes.create_unicode_buffer(wintypes.MAX_PATH)
                    ctypes.windll.shell32.SHGetFolderPathW(None, CSIDL_PERSONAL, None, SHGFP_TYPE_CURRENT, buf)
                    local_documents = buf.value
                except:
                    local_documents = os.path.join(home, "Documents") 
                    
                local_path = os.path.join(local_documents, game_name)
                onedrive_path = os.path.join(os.environ.get("USERPROFILE", ""), "OneDrive", "Documents", game_name)
                
                if os.path.exists(local_path): base_path = local_path
                elif os.path.exists(onedrive_path): base_path = onedrive_path
            else:
                app_id = "227300" if game_name == "Euro Truck Simulator 2" else "270880"
                linux_steam_path = os.path.join(home, ".steam", "steam", "steamapps", "compatdata", app_id, "pfx", "drive_c", "users", "steamuser", "Documents", game_name)
                if os.path.exists(linux_steam_path): base_path = linux_steam_path

        self.profile_dict.clear()
        
        if base_path:
            # Erkennt automatisch, ob der Nutzer den Hauptordner oder direkt "profiles" ausgewählt hat
            if os.path.basename(base_path.rstrip(r"\/")) == "profiles":
                profiles_dir = base_path
            elif os.path.exists(os.path.join(base_path, "profiles")):
                profiles_dir = os.path.join(base_path, "profiles")
            else:
                profiles_dir = base_path

            if os.path.exists(profiles_dir):
                for folder in os.listdir(profiles_dir):
                    if os.path.isdir(os.path.join(profiles_dir, folder)):
                        try:
                            # Wandelt die Hex-ID des Profilordners in lesbaren Text um
                            readable_name = bytes.fromhex(folder).decode('utf-8')
                            display_str = f"{readable_name} ({folder[:6]}...)"
                            self.profile_dict[display_str] = os.path.join(profiles_dir, folder, "controls.sii")
                        except: pass
                            
        if self.profile_dict:
            self.prof_combo.configure(values=list(self.profile_dict.keys()))
            self.prof_combo.set(list(self.profile_dict.keys())[0])
            self.update_backup_list()
        else:
            self.prof_combo.configure(values=[self.txt["no_profiles"]])
            self.prof_combo.set(self.txt["no_profiles"])
            self.backup_listbox.delete(0, tk.END)
            self.backup_listbox.insert(tk.END, self.txt["no_backups"])

    # BRÜCKEN-FUNKTION FÜR DEN MANUELLEN SUCHE-BUTTON
    def manuellen_ordner_auswaehlen(self):
        gewaehlter_ordner = filedialog.askdirectory(
            title="Wähle deinen ETS2-Hauptordner oder direkt 'profiles' aus"
        )
        if gewaehlter_ordner:
            self.suche_profile(alternativer_pfad=gewaehlter_ordner)

    # --- DEINE BACKUP-MANAGEMENT ENGINE ---
    def update_backup_list(self):
        self.backup_listbox.delete(0, tk.END)
        self.backup_list.clear()
        
        profil = self.selected_profile.get()
        if not profil or profil == self.txt["no_profiles"] or profil not in self.profile_dict:
            self.backup_listbox.insert(tk.END, self.txt["no_backups"])
            return
            
        dateipfad = self.profile_dict[profil]
        ordner = os.path.dirname(dateipfad)
        
        if os.path.exists(ordner):
            for datei in os.listdir(ordner):
                if datei.startswith("controls.sii.") and datei.endswith(".bak"):
                    self.backup_listbox.insert(tk.END, datei)
                    self.backup_list.append(os.path.join(ordner, datei))
                    
        if not self.backup_list:
            self.backup_listbox.insert(tk.END, self.txt["no_backups"])

    def restore_backup(self):
        selection = self.backup_listbox.curselection()
        if not selection or not self.backup_list:
            return
            
        index = selection[0]
        backup_file = self.backup_list[index]
        profil = self.selected_profile.get()
        target_file = self.profile_dict[profil]
        
        try:
            shutil.copy2(backup_file, target_file)
            self.lbl_status.configure(text=self.txt["status_success"], text_color="#2ecc71")
            messagebox.showinfo("Success", "Backup erfolgreich wiederhergestellt!")
        except Exception as e:
            self.lbl_status.configure(text=self.txt["status_error"], text_color="#e74c3c")
            messagebox.showerror("Error", str(e))

    def delete_backup(self):
        selection = self.backup_listbox.curselection()
        if not selection or not self.backup_list:
            return
            
        index = selection[0]
        backup_file = self.backup_list[index]
        
        try:
            os.remove(backup_file)
            self.update_backup_list()
            messagebox.showinfo("Success", "Backup erfolgreich gelöscht!")
        except Exception as e:
            messagebox.showerror("Error", str(e))

    # --- DEINE PRÄZISE WERT-INJEKTION FÜR DIE CONFIG_LINES ---
    def installieren(self):
        profil = self.selected_profile.get()
        if not profil or profil == self.txt["no_profiles"] or profil not in self.profile_dict:
            self.lbl_status.configure(text=self.txt["status_error"], text_color="#e74c3c")
            messagebox.showerror(self.txt["error"], self.txt["err_no_prof"])
            return
            
        dateipfad = self.profile_dict[profil]
        if not os.path.exists(dateipfad):
            messagebox.showerror(self.txt["error"], self.txt["err_no_file"])
            return
            
        try:
            timestamp = int(time.time())
            backup_pfad = f"{dateipfad}.{timestamp}.bak"
            shutil.copy2(dateipfad, backup_pfad)
            
            with open(dateipfad, "r", encoding="utf-8", errors="ignore") as f:
                zeilen = f.readlines()
                
            neue_zeilen = []
            for zeile in zeilen:
                if "constant c_rsteersens" in zeile:
                    try:
                        # Extrahiert das originale Array-Präfix [config_lines[X]...]
                        parts = zeile.split("[")
                        index = parts[1].split("]")
                        neue_zeilen.append(f' config_lines[{index[0]}] : "constant c_rsteersens 0.750000"\n')
                    except:
                        neue_zeilen.append(zeile)
                elif "constant c_steer_func" in zeile:
                    try:
                        parts = zeile.split("[")
                        index = parts[1].split("]")
                        neue_zeilen.append(f' config_lines[{index[0]}] : "constant c_steer_func 0.500000"\n')
                    except:
                        neue_zeilen.append(zeile)
                else:
                    neue_zeilen.append(zeile)
                    
            with open(dateipfad, "w", encoding="utf-8") as f:
                f.writelines(neue_zeilen)
                
            self.lbl_status.configure(text=self.txt["status_success"], text_color="#2ecc71")
            self.update_backup_list()
            messagebox.showinfo(self.txt["status_success"], f"{self.txt['status_success']}\n\n{self.txt['backup_created']}")
        except Exception as e:
            self.lbl_status.configure(text=self.txt["status_error"], text_color="#e74c3c")
            messagebox.showerror(self.txt["error"], str(e))

    # --- DEIN ORIGINALER THREADED GITHUB UPDATE CHECKER ---
    def check_for_updates(self):
        def _check():
            try:
                url = f"https://github.com{self.repo}/releases/latest"
                req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
                with urllib.request.urlopen(req) as response:
                    data = json.loads(response.read().decode())
                    latest_version = data["tag_name"].replace("v", "")
                    
                    if latest_version != self.version:
                        if messagebox.askyesno(self.txt["update_title"], self.txt["update_msg"].format(latest_version)):
                            if platform.system() == "Windows":
                                os.startfile(data["html_url"])
                            elif platform.system() == "Darwin":
                                subprocess.Popen(["open", data["html_url"]])
                            else:
                                subprocess.Popen(["xdg-open", data["html_url"]])
            except:
                pass
        threading.Thread(target=_check, daemon=True).start()

